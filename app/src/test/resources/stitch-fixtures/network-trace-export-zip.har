          "cookies": [],
          "content": {
            "size": 33164,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Run Card Enclave - LLM Hackathon Orchestration</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<style>\n        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap');\n        \n        @font-face {\n            font-family: 'metropolis';\n            src: url('https://fonts.cdnfonts.com/css/metropolis-2') format('woff2');\n            font-weight: 400 700;\n        }\n\n        :root {\n            --glass-bg: rgba(255, 255, 255, 0.03);\n            --glass-border: rgba(255, 255, 255, 0.1);\n        }\n\n        body {\n            background-color: #050505; /* Surface Level Base */\n            color: #e5e2e1;\n            font-family: 'JetBrains Mono', monospace;\n            overflow-x: hidden;\n            position: relative;\n        }\n\n        /* Ambient Glow Background - Updated for shifting dark blue/purple */\n        .ambient-glow {\n            position: fixed;\n            top: -50%;\n            left: -50%;\n            width: 200vw;\n            height: 200vh;\n            background: radial-gradient(circle at 30% 40%, rgba(2, 102, 255, 0.08) 0%, transparent 40%),\n                        radial-gradient(circle at 70% 60%, rgba(145, 0, 45, 0.06) 0%, transparent 50%),\n                        radial-gradient(circle at 50% 50%, rgba(0, 219, 233, 0.03) 0%, transparent 60%);\n            z-index: -1;\n            pointer-events: none;\n            animation: shift-glow 20s infinite alternate ease-in-out;\n            transform-origin: center center;\n        }\n\n        @keyframes shift-glow {\n            0% { transform: scale(1) translate(0, 0) rotate(0deg); }\n            50% { transform: scale(1.1) translate(2%, 2%) rotate(5deg); }\n            100% { transform: scale(1) translate(-2%, -2%) rotate(-5deg); }\n        }\n\n        /* Glass Panel Base */\n        .glass-panel {\n            background: var(--glass-bg);\n            backdrop-filter: blur(12px);\n            -webkit-backdrop-filter: blur(12px);\n            border: 1px solid var(--glass-border);\n            border-top: 1px solid rgba(255, 255, 255, 0.2); /* Top-light highlight */\n            border-radius: 0.125rem; /* DEFAULT radius */\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        /* Hover States for Challenge Cards */\n        .challenge-card {\n            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .challenge-card::before {\n            content: '';\n            position: absolute;\n            top: 0; left: 0; right: 0; bottom: 0;\n            background: linear-gradient(45deg, transparent, rgba(0, 219, 233, 0.1), transparent);\n            transform: translateX(-100%);\n            transition: transform 0.6s ease;\n            z-index: 0;\n            pointer-events: none;\n        }\n\n        .challenge-card:hover {\n            border-color: #7df4ff;\n            box-shadow: 0 0 15px rgba(0, 219, 233, 0.3), inset 0 0 20px rgba(0, 219, 233, 0.05);\n            transform: translateY(-4px) scale(1.02);\n            background: rgba(255, 255, 255, 0.05);\n            animation: panel-flicker 0.1s 2;\n        }\n\n        .challenge-card:hover::before {\n            transform: translateX(100%);\n        }\n\n        @keyframes panel-flicker {\n            0% { opacity: 1; }\n            50% { opacity: 0.8; background: rgba(0, 219, 233, 0.1); }\n            100% { opacity: 1; }\n        }\n\n\n        .glass-panel.active {\n            border-color: #7df4ff; /* Primary Cyan */\n            box-shadow: 0 0 15px 0 rgba(125, 244, 255, 0.5); /* Outer glow */\n            animation: active-pulse 2s infinite;\n        }\n        \n        @keyframes active-pulse {\n            0% { box-shadow: 0 0 10px 0 rgba(125, 244, 255, 0.3); }\n            50% { box-shadow: 0 0 20px 0 rgba(125, 244, 255, 0.6); }\n            100% { box-shadow: 0 0 10px 0 rgba(125, 244, 255, 0.3); }\n        }\n\n        /* Sync Pill Animation */\n        .sync-pill-container {\n            position: relative;\n            display: inline-flex;\n            align-items: center;\n        }\n\n        .sync-pill-idle {\n            width: 8px;\n            height: 64px;\n            background: var(--glass-bg);\n            backdrop-filter: blur(12px);\n            border: 1px solid var(--glass-border);\n            border-radius: 4px;\n            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            cursor: pointer;\n            box-shadow: 0 0 10px rgba(0, 219, 233, 0.2);\n            animation: idle-pulse 2s infinite;\n        }\n\n        @keyframes idle-pulse {\n            0% { box-shadow: 0 0 5px rgba(0, 219, 233, 0.2); }\n            50% { box-shadow: 0 0 15px rgba(0, 219, 233, 0.5); }\n            100% { box-shadow: 0 0 5px rgba(0, 219, 233, 0.2); }\n        }\n\n        .sync-pill-active {\n            display: flex;\n            align-items: center;\n            gap: 24px;\n            padding: 16px 32px;\n            background: var(--glass-bg);\n            backdrop-filter: blur(12px);\n            border: 1px solid #7df4ff;\n            border-radius: 32px; /* Pill shape */\n            opacity: 0;\n            transform: scale(0.9) translateX(-20px);\n            pointer-events: none;\n            position: absolute;\n            left: 0;\n            white-space: nowrap;\n            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            box-shadow: 0 0 15px rgba(0, 219, 233, 0.4);\n            animation: border-flicker 3s infinite;\n        }\n\n        @keyframes border-flicker {\n            0%, 100% { border-color: rgba(125, 244, 255, 0.5); }\n            50% { border-color: rgba(125, 244, 255, 1); box-shadow: 0 0 20px rgba(0, 219, 233, 0.6); }\n            52% { border-color: rgba(125, 244, 255, 0.2); }\n            54% { border-color: rgba(125, 244, 255, 1); }\n        }\n\n        .sync-pill-container.expanded .sync-pill-idle {\n            opacity: 0;\n            transform: scale(0.5);\n            pointer-events: none;\n        }\n\n        .sync-pill-container.expanded .sync-pill-active {\n            opacity: 1;\n            transform: scale(1) translateX(0);\n            pointer-events: auto;\n            position: relative;\n        }\n\n        /* Rotating Scanning Animation */\n        .scanner-circle {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            border-radius: 50%;\n            border: 2px solid transparent;\n            border-top-color: #7df4ff;\n            border-right-color: rgba(125, 244, 255, 0.3);\n            animation: scan-rotate 1.5s linear infinite;\n        }\n        \n        .scanner-circle::after {\n            content: '';\n            position: absolute;\n            top: -2px; left: 50%;\n            width: 4px; height: 4px;\n            background: #fff;\n            border-radius: 50%;\n            box-shadow: 0 0 8px #7df4ff;\n        }\n\n        @keyframes scan-rotate {\n            0% { transform: rotate(0deg); }\n            100% { transform: rotate(360deg); }\n        }\n\n        /* Scanline Animation for loading/processing */\n        .scanline-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(to bottom, transparent 50%, rgba(0, 219, 233, 0.05) 51%);\n            background-size: 100% 4px;\n            pointer-events: none;\n            z-index: 10;\n            opacity: 0.5;\n            animation: scanlines-move 10s linear infinite;\n        }\n        \n        @keyframes scanlines-move {\n            0% { background-position: 0 0; }\n            100% { background-position: 0 100%; }\n        }\n\n        /* Button Flicker */\n        .btn-primary {\n            background-color: #dbfcff; /* Primary */\n            color: #002022; /* on-primary-fixed */\n            transition: all 0.15s;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .btn-primary::after {\n            content: '';\n            position: absolute;\n            top: -50%; left: -50%;\n            width: 200%; height: 200%;\n            background: linear-gradient(rgba(255,255,255,0.8), rgba(255,255,255,0));\n            transform: rotate(45deg) translateY(-100%);\n            transition: transform 0.3s;\n        }\n        \n        .btn-primary:hover::after {\n            transform: rotate(45deg) translateY(100%);\n        }\n\n        .btn-primary:active, .btn-primary.flicker {\n            filter: brightness(1.5);\n            transform: scale(0.98);\n        }\n\n        .btn-ghost {\n            border: 1px solid #dbfcff;\n            color: #dbfcff;\n            background: transparent;\n            transition: all 0.2s;\n        }\n        .btn-ghost:hover {\n            background-color: rgba(219, 252, 255, 0.1);\n            box-shadow: inset 0 0 10px rgba(0, 219, 233, 0.2);\n        }\n\n        /* Terminal Cursor */\n        .cursor-blink {\n            display: inline-block;\n            width: 8px;\n            height: 1.2em;\n            background-color: #00dbe9;\n            animation: blink 1s step-end infinite;\n            vertical-align: middle;\n            margin-left: 4px;\n        }\n        @keyframes blink { 50% { opacity: 0; } }\n        \n        /* Grid Lines */\n        .bg-grid {\n            background-size: 32px 32px;\n            background-image: linear-gradient(to right, rgba(255, 255, 255, 0.02) 1px, transparent 1px),\n                              linear-gradient(to bottom, rgba(255, 255, 255, 0.02) 1px, transparent 1px);\n            animation: grid-pan 60s linear infinite;\n        }\n        \n        @keyframes grid-pan {\n            0% { background-position: 0 0; }\n            100% { background-position: 32px 32px; }\n        }\n        \n        /* Monospace Flicker */\n        .mono-flicker {\n            animation: text-flicker 4s infinite random;\n        }\n        \n        @keyframes text-flicker {\n            0%, 95%, 100% { opacity: 1; }\n            96% { opacity: 0.4; }\n            97% { opacity: 0.8; }\n            98% { opacity: 0.2; }\n            99% { opacity: 1; text-shadow: 0 0 5px #7df4ff; }\n        }\n\n        /* Entrance Animations */\n        .reveal-element {\n            opacity: 0;\n            transform: translateY(30px) scale(0.95);\n            transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n        \n        .reveal-element.visible {\n            opacity: 1;\n            transform: translateY(0) scale(1);\n        }\n\n        .delay-100 { transition-delay: 100ms; }\n        .delay-200 { transition-delay: 200ms; }\n        .delay-300 { transition-delay: 300ms; }\n    </style>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n          darkMode: \"class\",\n          theme: {\n            extend: {\n              \"colors\": {\n                      \"on-primary-fixed-variant\": \"#004f54\",\n                      \"surface\": \"#131313\",\n                      \"error-container\": \"#93000a\",\n                      \"on-surface\": \"#e5e2e1\",\n                      \"surface-container\": \"#201f1f\",\n                      \"tertiary-fixed\": \"#ffdadb\",\n                      \"on-error-container\": \"#ffdad6\",\n                      \"on-secondary-fixed\": \"#001849\",\n                      \"outline-variant\": \"#3b494b\",\n                      \"inverse-surface\": \"#e5e2e1\",\n                      \"on-tertiary-container\": \"#be003d\",\n                      \"surface-container-low\": \"#1c1b1b\",\n                      \"outline\": \"#849495\",\n                      \"secondary-fixed-dim\": \"#b3c5ff\",\n                      \"surface-dim\": \"#131313\",\n                      \"surface-tint\": \"#00dbe9\",\n                      \"secondary-container\": \"#0266ff\",\n                      \"tertiary-container\": \"#ffcdd0\",\n                      \"primary-fixed\": \"#7df4ff\",\n                      \"surface-container-high\": \"#2a2a2a\",\n                      \"inverse-primary\": \"#006970\",\n                      \"tertiary\": \"#fff3f3\",\n                      \"on-tertiary\": \"#67001d\",\n                      \"primary\": \"#dbfcff\",\n                      \"on-secondary-fixed-variant\": \"#003fa4\",\n                      \"on-primary-fixed\": \"#002022\",\n                      \"surface-bright\": \"#3a3939\",\n                      \"on-tertiary-fixed-variant\": \"#91002d\",\n                      \"primary-container\": \"#00f0ff\",\n                      \"secondary-fixed\": \"#dae1ff\",\n                      \"surface-variant\": \"#353534\",\n                      \"on-primary\": \"#00363a\",\n                      \"on-tertiary-fixed\": \"#40000f\",\n                      \"inverse-on-surface\": \"#313030\",\n                      \"on-primary-container\": \"#006970\",\n                      \"on-error\": \"#690005\",\n                      \"error\": \"#ffb4ab\",\n                      \"secondary\": \"#b3c5ff\",\n                      \"tertiary-fixed-dim\": \"#ffb2b8\",\n                      \"surface-container-lowest\": \"#0e0e0e\",\n                      \"background\": \"#131313\",\n                      \"on-secondary-container\": \"#f9f7ff\",\n                      \"on-background\": \"#e5e2e1\",\n                      \"surface-container-highest\": \"#353534\",\n                      \"primary-fixed-dim\": \"#00dbe9\",\n                      \"on-surface-variant\": \"#b9cacb\",\n                      \"on-secondary\": \"#002b75\"\n              },\n              \"borderRadius\": {\n                      \"DEFAULT\": \"0.125rem\",\n                      \"lg\": \"0.25rem\",\n                      \"xl\": \"0.5rem\",\n                      \"full\": \"0.75rem\"\n              },\n              \"spacing\": {\n                      \"unit\": \"4px\",\n                      \"margin-sm\": \"24px\",\n                      \"gutter\": \"16px\",\n                      \"margin-lg\": \"64px\",\n                      \"panel-padding\": \"20px\"\n              },\n              \"fontFamily\": {\n                      \"headline-lg\": [\n                              \"metropolis\"\n                      ],\n                      \"code-sm\": [\n                              \"jetbrainsMono\"\n                      ],\n                      \"headline-xl\": [\n                              \"metropolis\"\n                      ],\n                      \"body-md\": [\n                              \"jetbrainsMono\"\n                      ],\n                      \"headline-lg-mobile\": [\n                              \"metropolis\"\n                      ],\n                      \"label-caps\": [\n                              \"jetbrainsMono\"\n                      ]\n              },\n              \"fontSize\": {\n                      \"headline-lg\": [\n                              \"32px\",\n                              {\n                                      \"lineHeight\": \"40px\",\n                                      \"letterSpacing\": \"0.01em\",\n                                      \"fontWeight\": \"600\"\n                              }\n                      ],\n                      \"code-sm\": [\n                              \"12px\",\n                              {\n                                      \"lineHeight\": \"18px\",\n                                      \"fontWeight\": \"500\"\n                              }\n                      ],\n                      \"headline-xl\": [\n                              \"48px\",\n                              {\n                                      \"lineHeight\": \"56px\",\n                                      \"letterSpacing\": \"0.02em\",\n                                      \"fontWeight\": \"700\"\n                              }\n                      ],\n                      \"body-md\": [\n                              \"14px\",\n                              {\n                                      \"lineHeight\": \"24px\",\n                                      \"fontWeight\": \"400\"\n                              }\n                      ],\n                      \"headline-lg-mobile\": [\n                              \"24px\",\n                              {\n                                      \"lineHeight\": \"32px\",\n                                      \"fontWeight\": \"600\"\n                              }\n                      ],\n                      \"label-caps\": [\n                              \"10px\",\n                              {\n                                      \"lineHeight\": \"12px\",\n                                      \"letterSpacing\": \"0.1em\",\n                                      \"fontWeight\": \"700\"\n                              }\n                      ]\n              }\n            }\n          }\n        }\n      </script>\n</head>\n<body class=\"bg-surface text-on-surface antialiased bg-grid relative selection:bg-primary-fixed selection:text-on-primary-fixed\">\n<div class=\"ambient-glow\"></div>\n<!-- TopNavBar Component -->\n<nav class=\"fixed top-0 w-full z-50 bg-surface/30 backdrop-blur-xl border-b border-white/10 bg-surface-container-lowest/10 transition-all duration-300\">\n<div class=\"flex justify-between items-center px-margin-lg h-16 w-full max-w-7xl mx-auto\">\n<div class=\"font-headline-lg text-headline-lg font-bold text-primary-fixed-dim tracking-tighter hover:scale-105 transition-transform cursor-pointer\">\n                RUN_CARD\n            </div>\n<div class=\"hidden md:flex space-x-8 font-label-caps text-label-caps uppercase tracking-widest\">\n<a class=\"text-primary-fixed-dim border-b border-primary-fixed-dim pb-1 mono-flicker\" href=\"#\">Enclave</a>\n<a class=\"text-on-surface-variant hover:text-primary-fixed hover:bg-white/5 transition-all duration-150 py-1 px-2\" href=\"#\">Orchestration</a>\n<a class=\"text-on-surface-variant hover:text-primary-fixed hover:bg-white/5 transition-all duration-150 py-1 px-2\" href=\"#\">Challenges</a>\n<a class=\"text-on-surface-variant hover:text-primary-fixed hover:bg-white/5 transition-all duration-150 py-1 px-2\" href=\"#\">Analytics</a>\n</div>\n<div class=\"flex items-center space-x-4 font-label-caps text-label-caps uppercase tracking-widest\">\n<a class=\"text-on-surface-variant hover:text-primary-fixed hover:bg-white/5 transition-all duration-150 py-1 px-2 hidden md:block mono-flicker\" href=\"#\">Documentation</a>\n<button class=\"btn-primary px-4 py-2 uppercase tracking-widest font-bold\" onclick=\"this.classList.add('flicker'); setTimeout(() =&gt; this.classList.remove('flicker'), 100)\">\n                    Connect Enclave\n                </button>\n</div>\n</div>\n</nav>\n<main class=\"pt-32 pb-24 max-w-7xl mx-auto px-margin-sm md:px-margin-lg relative z-10 flex flex-col gap-32\">\n<!-- Hero Section -->\n<section class=\"flex flex-col md:flex-row items-center justify-between gap-16 min-h-[614px] reveal-element visible\">\n<div class=\"w-full md:w-3/5 space-y-8 relative\">\n<div class=\"absolute -left-8 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-primary-fixed-dim/50 to-transparent\"></div>\n<h1 class=\"font-headline-xl text-headline-xl md:text-[64px] md:leading-[72px] text-on-surface uppercase tracking-tighter\">\n                    Orchestrate<br/>\n                    The Next<br/>\n<span class=\"text-primary-fixed-dim inline-block hover:scale-105 transition-transform duration-300\">Generation</span><br/>\n                    Of AI Challenges\n                </h1>\n<p class=\"font-body-md text-body-md text-on-surface-variant max-w-xl\">\n                    Deploy secure, isolated compute environments for LLM agents. Monitor token spend, validate tool calls, and enforce logic boundaries in real-time.<span class=\"cursor-blink\"></span>\n</p>\n<div class=\"flex items-center gap-6 pt-4\">\n<button class=\"btn-primary px-6 py-3 font-label-caps text-label-caps uppercase tracking-widest font-bold flex items-center gap-2 group\">\n<span class=\"material-symbols-outlined text-[16px] group-hover:rotate-180 transition-transform duration-500\">terminal</span>\n                        Initialize Hackathon\n                    </button>\n<button class=\"btn-ghost px-6 py-3 font-label-caps text-label-caps uppercase tracking-widest flex items-center gap-2 group\">\n                        View API Specs\n                        <span class=\"material-symbols-outlined text-[16px] opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all\">arrow_forward</span>\n</button>\n</div>\n</div>\n<!-- Sync Pill Interactive Element -->\n<div class=\"w-full md:w-2/5 flex justify-end h-64 items-center\">\n<div class=\"sync-pill-container\" id=\"heroSyncPill\" onclick=\"this.classList.toggle('expanded'); animateCounters();\">\n<div class=\"sync-pill-idle\" title=\"Click to expand enclave metrics\"></div>\n<div class=\"sync-pill-active glass-panel\">\n<div class=\"relative w-16 h-16 rounded-full flex items-center justify-center\">\n<div class=\"scanner-circle\"></div>\n<div class=\"absolute w-12 h-12 border border-primary-fixed/30 rounded-full\"></div>\n<div class=\"w-8 h-8 bg-primary-fixed/20 rounded-full flex items-center justify-center relative z-10\">\n<div class=\"w-2 h-2 bg-primary-fixed rounded-full animate-pulse\"></div>\n</div>\n</div>\n<div class=\"flex flex-col gap-2 font-code-sm text-code-sm uppercase\">\n<div class=\"text-primary-fixed mb-1 font-bold tracking-widest mono-flicker\">SYNCING_</div>\n<div class=\"flex justify-between gap-8 text-on-surface-variant\">\n<span>LATENCY</span> <span class=\"text-on-surface counter\" data-target=\"4\">00MS</span>\n</div>\n<div class=\"flex justify-between gap-8 text-on-surface-variant\">\n<span>CHANNEL</span> <span class=\"text-primary-fixed mono-flicker\">READY</span>\n</div>\n<div class=\"flex justify-between gap-8 text-on-surface-variant\">\n<span>TOKENS</span> <span class=\"text-on-surface counter\" data-target=\"8429\">0000</span>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- The Enclave Engine Diagram -->\n<section class=\"space-y-8 reveal-element delay-100\">\n<div class=\"flex items-end justify-between border-b border-white/10 pb-4\">\n<h2 class=\"font-headline-lg text-headline-lg text-on-surface uppercase tracking-tighter\">The Enclave Engine</h2>\n<span class=\"font-code-sm text-code-sm text-primary-fixed-dim uppercase mono-flicker\">SYS_ARCH // 01</span>\n</div>\n<div class=\"glass-panel p-panel-padding relative overflow-hidden h-[400px] flex items-center justify-center group hover:border-primary-fixed/50 transition-colors duration-500\">\n<div class=\"scanline-overlay group-hover:opacity-80 transition-opacity\"></div>\n<!-- Abstract visual representation of architecture -->\n<div class=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1620641788421-7a1c342ea42e?q=80&amp;w=2000&amp;auto=format&amp;fit=crop')] bg-cover bg-center opacity-20 mix-blend-luminosity group-hover:scale-105 transition-transform duration-700\" data-alt=\"Abstract rendering of a digital data core. Dark, minimalist background with intersecting beams of glowing cyan light simulating a high-tech computational matrix. The aesthetic is hardware-precise, cold, and sterile, emphasizing latency-first data transmission and secure edge computing. Deep blacks contrast with sharp, bright cyan accents.\"></div>\n<div class=\"relative z-10 w-full max-w-4xl flex justify-between items-center px-12\">\n<!-- Left Node -->\n<div class=\"flex flex-col items-center gap-4 relative z-20 hover:-translate-y-2 transition-transform duration-300\">\n<div class=\"w-16 h-16 border border-white/20 rounded-sm flex items-center justify-center bg-surface-container/50 hover:border-primary-fixed/50 transition-colors\">\n<span class=\"material-symbols-outlined text-on-surface-variant\">smart_toy</span>\n</div>\n<span class=\"font-code-sm text-code-sm text-on-surface-variant mono-flicker\">AGENT_SWARM</span>\n</div>\n<!-- Connection Line with data packet -->\n<div class=\"flex-1 h-px bg-white/10 relative overflow-hidden mx-4\">\n<div class=\"absolute top-0 left-0 h-full w-16 bg-primary-fixed shadow-[0_0_15px_#7df4ff] animate-[slide-right_1.5s_linear_infinite]\"></div>\n</div>\n<!-- Center Core -->\n<div class=\"glass-panel p-6 border-primary-fixed flex flex-col items-center gap-2 active relative z-20 hover:scale-110 transition-transform duration-300\">\n<span class=\"material-symbols-outlined text-primary-fixed text-4xl\">security</span>\n<span class=\"font-code-sm text-code-sm text-primary-fixed font-bold tracking-widest mt-2 mono-flicker\">RUN_CARD CORE</span>\n<span class=\"font-label-caps text-label-caps text-on-surface-variant block text-center opacity-80\">VALIDATION LAYER<br/>INTERCEPT / SANITIZE</span>\n</div>\n<!-- Connection Line -->\n<div class=\"flex-1 h-px bg-white/10 relative mx-4 overflow-hidden\">\n<div class=\"absolute top-0 left-0 h-full w-16 bg-primary-fixed shadow-[0_0_15px_#7df4ff] animate-[slide-right_1.5s_linear_infinite] delay-700\"></div>\n</div>\n<!-- Right Node -->\n<div class=\"flex flex-col items-center gap-4 relative z-20 hover:-translate-y-2 transition-transform duration-300\">\n<div class=\"w-16 h-16 border border-white/20 rounded-sm flex items-center justify-center bg-surface-container/50 hover:border-primary-fixed/50 transition-colors\">\n<span class=\"material-symbols-outlined text-on-surface-variant\">database</span>\n</div>\n<span class=\"font-code-sm text-code-sm text-on-surface-variant mono-flicker\">SECURE_DATA</span>\n</div>\n</div>\n</div>\n</section>\n<!-- Challenge Modes -->\n<section class=\"space-y-8 reveal-element delay-200\">\n<div class=\"flex items-end justify-between border-b border-white/10 pb-4\">\n<h2 class=\"font-headline-lg text-headline-lg text-on-surface uppercase tracking-tighter\">Execution Modes</h2>\n<span class=\"font-code-sm text-code-sm text-primary-fixed-dim uppercase mono-flicker\">MOD_LOAD // 02</span>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-3 gap-gutter\">\n<!-- Card 1 -->\n<div class=\"glass-panel challenge-card p-panel-padding flex flex-col gap-6\">\n<div class=\"relative z-10 flex justify-between items-start\">\n<span class=\"material-symbols-outlined text-primary-fixed text-[32px] transition-transform duration-300 group-hover:scale-110\">memory</span>\n<span class=\"font-code-sm text-code-sm text-on-surface-variant border border-white/10 px-2 py-1 rounded-[2px] mono-flicker\">OPT_TKN</span>\n</div>\n<div class=\"relative z-10\">\n<h3 class=\"font-code-sm text-code-sm font-bold text-on-surface uppercase tracking-widest mb-2 group-hover:text-primary-fixed transition-colors\">Token Optimization</h3>\n<p class=\"font-body-md text-body-md text-on-surface-variant text-[12px] leading-relaxed\">\n                            Strict budgets enforced at the network layer. Automatically terminate runs exceeding allocated context limits.\n                        </p>\n</div>\n<div class=\"mt-auto pt-4 border-t border-white/5 flex justify-between font-label-caps text-label-caps relative z-10\">\n<span class=\"text-on-surface-variant\">STATUS:</span>\n<span class=\"text-primary-fixed mono-flicker\">ONLINE</span>\n</div>\n</div>\n<!-- Card 2 -->\n<div class=\"glass-panel challenge-card p-panel-padding flex flex-col gap-6 delay-100\">\n<div class=\"relative z-10 flex justify-between items-start\">\n<span class=\"material-symbols-outlined text-primary-fixed text-[32px] transition-transform duration-300 group-hover:scale-110\">route</span>\n<span class=\"font-code-sm text-code-sm text-on-surface-variant border border-white/10 px-2 py-1 rounded-[2px] mono-flicker\">1_SHOT</span>\n</div>\n<div class=\"relative z-10\">\n<h3 class=\"font-code-sm text-code-sm font-bold text-on-surface uppercase tracking-widest mb-2 group-hover:text-primary-fixed transition-colors\">One-Shot Logic</h3>\n<p class=\"font-body-md text-body-md text-on-surface-variant text-[12px] leading-relaxed\">\n                            Zero-retry environments. Force agents to deduce correct tool sequences without iterative safety nets.\n                        </p>\n</div>\n<div class=\"mt-auto pt-4 border-t border-white/5 flex justify-between font-label-caps text-label-caps relative z-10\">\n<span class=\"text-on-surface-variant\">STATUS:</span>\n<span class=\"text-primary-fixed mono-flicker\">ONLINE</span>\n</div>\n</div>\n<!-- Card 3 -->\n<div class=\"glass-panel challenge-card p-panel-padding flex flex-col gap-6 delay-200\">\n<div class=\"relative z-10 flex justify-between items-start\">\n<span class=\"material-symbols-outlined text-primary-fixed text-[32px] transition-transform duration-300 group-hover:scale-110\">hub</span>\n<span class=\"font-code-sm text-code-sm text-on-surface-variant border border-white/10 px-2 py-1 rounded-[2px] mono-flicker\">SWRM_X</span>\n</div>\n<div class=\"relative z-10\">\n<h3 class=\"font-code-sm text-code-sm font-bold text-on-surface uppercase tracking-widest mb-2 group-hover:text-primary-fixed transition-colors\">Agent Swarms</h3>\n<p class=\"font-body-md text-body-md text-on-surface-variant text-[12px] leading-relaxed\">\n                            Multi-agent IPC routing. Monitor communication overhead and inter-agent token exchange rates.\n                        </p>\n</div>\n<div class=\"mt-auto pt-4 border-t border-white/5 flex justify-between font-label-caps text-label-caps relative z-10\">\n<span class=\"text-on-surface-variant\">STATUS:</span>\n<span class=\"text-primary-fixed mono-flicker\">ONLINE</span>\n</div>\n</div>\n</div>\n</section>\n</main>\n<!-- Footer Component -->\n<footer class=\"bg-surface-container-lowest w-full py-12 px-margin-lg border-t border-white/5 flat no shadows reveal-element delay-300\">\n<div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-gutter\">\n<div class=\"font-headline-lg-mobile text-headline-lg-mobile text-on-surface font-bold tracking-tighter hover:text-primary-fixed transition-colors cursor-pointer\">\n                RUN_CARD\n            </div>\n<div class=\"flex flex-wrap justify-center gap-8 font-code-sm text-code-sm\">\n<a class=\"text-on-surface-variant hover:text-primary transition-colors\" href=\"#\">Documentation</a>\n<a class=\"text-on-surface-variant hover:text-primary transition-colors\" href=\"#\">Run Card Project</a>\n<a class=\"text-on-surface-variant hover:text-primary transition-colors\" href=\"#\">Terms of Service</a>\n<a class=\"text-on-surface-variant hover:text-primary transition-colors\" href=\"#\">Security Audit</a>\n</div>\n<div class=\"font-code-sm text-code-sm text-on-surface-variant uppercase tracking-widest mono-flicker\">\n                © 2024 RUN_CARD ENCLAVE PROTOCOL. ALL RIGHTS RESERVED.\n            </div>\n</div>\n</footer>\n<style>\n        @keyframes slide-right {\n            0% { left: -10%; }\n            100% { left: 110%; }\n        }\n    </style>\n<script>\n        // Entrance Animations Observer\n        const observerOptions = {\n            root: null,\n            rootMargin: '0px',\n            threshold: 0.1\n        };\n\n        const observer = new IntersectionObserver((entries, observer) => {\n            entries.forEach(entry => {\n                if (entry.isIntersecting) {\n                    entry.target.classList.add('visible');\n                    observer.unobserve(entry.target);\n                }\n            });\n        }, observerOptions);\n\n        document.querySelectorAll('.reveal-element').forEach((el) => {\n            observer.observe(el);\n        });\n\n        // Add mono-flicker randomly\n        const monoElements = document.querySelectorAll('.font-code-sm, .font-label-caps');\n        monoElements.forEach(el => {\n            if(Math.random() > 0.7 && !el.classList.contains('mono-flicker')) {\n                el.classList.add('mono-flicker');\n                // Randomize animation duration for a more organic feel\n                el.style.animationDuration = (Math.random() * 3 + 2) + 's';\n            }\n        });\n        \n        // Counter Animation\n        function animateCounters() {\n            const counters = document.querySelectorAll('.counter');\n            const speed = 200; // The lower the slower\n\n            counters.forEach(counter => {\n                const updateCount = () => {\n                    const target = +counter.getAttribute('data-target');\n                    const count = +counter.innerText.replace(/\\D/g, ''); // Remove non-digits\n                    const isLatency = counter.innerText.includes('MS');\n\n                    const inc = target / speed;\n\n                    if (count < target) {\n                        let nextVal = Math.ceil(count + inc);\n                        if(nextVal > target) nextVal = target;\n                        \n                        counter.innerText = isLatency ? \n                            (nextVal < 10 ? '0' + nextVal : nextVal) + 'MS' : \n                            (nextVal < 1000 && target > 1000 ? '0' + nextVal : nextVal);\n                            \n                        setTimeout(updateCount, 20);\n                    } else {\n                        counter.innerText = isLatency ? \n                            (target < 10 ? '0' + target : target) + 'MS' : target;\n                    }\n                };\n\n                // Reset before animating\n                counter.innerText = counter.innerText.includes('MS') ? '00MS' : '0000';\n                setTimeout(updateCount, 500); // slight delay after expansion\n            });\n        }\n    </script>\n</body></html>"
