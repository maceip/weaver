{
  "_comment": "ECS Fargate task definition for the Weaver session bridge. Register with `aws ecs register-task-definition --cli-input-json file://ecs-task-definition.json`. Replace <ACCOUNT>, <REGION>, and the image tag. 2 vCPU / 4 GB comfortably holds one Chromium with a few dozen BrowserContexts; scale out (more tasks) rather than up.",
  "family": "weaver-session-bridge",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::<ACCOUNT>:role/weaverSessionBridgeExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT>:role/weaverSessionBridgeTaskRole",
  "containerDefinitions": [
    {
      "name": "session-bridge",
      "image": "<ACCOUNT>.dkr.ecr.<REGION>.amazonaws.com/weaver-session-bridge:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8080, "protocol": "tcp" }],
      "environment": [
        { "name": "PORT", "value": "8080" },
        { "name": "WEAVER_ALLOWED_AUDIENCES", "value": "REPLACE_WITH_OAUTH_WEB_CLIENT_ID" },
        { "name": "WEAVER_MAX_CONTEXTS", "value": "40" },
        { "name": "WEAVER_CONTEXT_IDLE_MS", "value": "900000" }
      ],
      "linuxParameters": {
        "initProcessEnabled": true
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"fetch('http://localhost:8080/healthz').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/weaver/session-bridge",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "bridge"
        }
      }
    }
  ]
}
