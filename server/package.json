{
  "name": "weaver-session-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Remote session bridge: owns an authenticated Stitch browser and projects it to the Weaver Android client.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --import tsx --watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@peculiar/x509": "^1.12.3",
    "asn1js": "^3.0.5",
    "fastify": "^5.2.0",
    "jose": "^5.9.6",
    "playwright": "^1.49.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
